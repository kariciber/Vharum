name: Deploy Vharum Game to GitHub Pages

on:
  push:
    branches: [ "main" ]   # se ejecuta cada vez que haces push en main
  workflow_dispatch:        # permite ejecutarlo manualmente desde Actions

permissions:
  contents: read
  pages: write
  id-token: write

concurrency:
  group: "pages"
  cancel-in-progress: true

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repo
        uses: actions/checkout@v4

      # No hay paso de compilación, solo HTML y assets
      - name: Upload static site
        uses: actions/upload-pages-artifact@v3
        with:
          path: "."   # publica todo el contenido raíz

  deploy:
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    runs-on: ubuntu-latest
    needs: build
    steps:
      - name: Deploy to GitHub Pages
        id: deployment
        uses: actions/deploy-pages@v4

